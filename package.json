{
  "name": "seer-survival-lookup",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "build:standalone": "npm run build && node scripts/build_standalone.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:py": "python3 -m unittest discover -s tests/python -p 'test_*.py'",
    "build:data": "PYTHONPATH=scripts python3 scripts/build_lookup.py --input 统计表.xlsx --output public/data"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vitest": "^2.1.0"
  }
}
